#!/bin/bash
# Pre-push hook: verify that addon .toc version is bumped when code changes

remote="$1"

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"
    else
        range="${remote_sha}..${local_sha}"
    fi

    changed_files=$(git diff --name-only "$range" 2>/dev/null)

    for addon_dir in ZaeUI_*/; do
        addon_name="${addon_dir%/}"
        toc_file="${addon_name}/${addon_name}.toc"

        code_changed=$(echo "$changed_files" | grep -E "^${addon_name}/.*\.(lua|toc|xml)$" | grep -v "README" || true)
        version_bumped=$(echo "$changed_files" | grep -F "$toc_file" || true)

        if [ -n "$code_changed" ] && [ -z "$version_bumped" ]; then
            # Check if the version line specifically changed
            version_diff=$(git diff "$range" -- "$toc_file" 2>/dev/null | grep -E '^\+## Version:' || true)
            if [ -z "$version_diff" ]; then
                echo "ERROR: ${addon_name} has code changes but ## Version in ${toc_file} was not updated."
                echo "Bump the version before pushing."
                exit 1
            fi
        fi
    done
done

exit 0
